# ---- KasmVNC container user ----
PUID=1000
PGID=1000
CUSTOM_USER=abc
PASSWORD=securepassword

# ---- MT5 account credentials ----
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ---- MT5 terminal settings ----
MT5_INSTALL_DIR=PXBT Trading MT5 Terminal
MT5_SETUP_URL=https://download.terminal.free/cdn/web/pxbt.trading.ltd/mt5/pxbttrading5setup.exe
MT5_RPYC_PORT=8001

# ---- Startup EA (leave empty to skip) ----
MT5_STARTUP_EA=MasterTrader
MT5_STARTUP_SYMBOL=XAUUSD
MT5_STARTUP_PERIOD=M1

# ---- Extra terminal flags ----
MT5_CMD_OPTIONS=

# ---- Mode: "live" (default) or "tester" (backtest) ----
MT5_MODE=live
